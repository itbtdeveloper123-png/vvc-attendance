# Example environment variables for AI configuration
# DO NOT store real secrets in the repository. Copy this to a local .env and set real keys there.

# GitHub API token (personal access token) used for GitHub API calls only
GITHUB_API_KEY=

# Pollinations.ai API key used by the Product Analyzer
POLLINATIONS_API_KEY=

# Model selection
AI_PUBLIC_MODEL=gemini-2.5-flash     # recommended for general public questions
AI_CODE_MODEL=gpt-4o                 # recommended for GitHub/code related tasks

# Toggle that blocks sending internal/private content to external LLMs
# When set to true, any request flagged as INTERNAL will be refused instead of forwarded.
BLOCK_INTERNAL_EXTERNAL=true

# Other keys (retain existing app keys but keep them local)
# OPENAI_API_KEY=  # if still used elsewhere, keep in local .env only
